#!/usr/bin/env python3
"""Launcher shim installed to /usr/local/bin/exopinet-wiki."""
import os
import sys

APP_HOME = os.environ.get("EXOPINET_HOME", "/opt/exopinet-wiki")
if APP_HOME not in sys.path:
    sys.path.insert(0, APP_HOME)

from exopinet_wiki.app import main  # noqa: E402

if __name__ == "__main__":
    main()
